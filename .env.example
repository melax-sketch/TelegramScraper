# ============================================================
# REQUIRED - Get from https://my.telegram.org/apps
# ============================================================
API_ID=12345678
API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# TELEGRAM ACCOUNT LOGIN
# ============================================================
SESSION_PASSWORD=your_secure_password_here

# ============================================================
# TELEGRAM BOT (for management bot)
# ============================================================
# Get BOT_TOKEN from @BotFather on Telegram
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your Telegram user ID (get from @userinfobot)
# This restricts bot access to only you
OWNER_ID=123456789

# ============================================================
# DIRECTORIES
# ============================================================
SESSIONS_DIR=./sessions
CSV_OUTPUT_DIR=./output
LOG_DIR=./logs

# ============================================================
# LOGGING
# ============================================================
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# PERFORMANCE SETTINGS
# ============================================================
MEMBERS_BATCH_SIZE=200
MAX_MESSAGE_HISTORY=100000
REQUEST_DELAY=1
BROADCAST_DELAY_MIN=30
BROADCAST_DELAY_MAX=60

# ============================================================
# FEATURES
# ============================================================
ENABLE_FLOODWAIT_HANDLING=true
ENABLE_SESSION_ENCRYPTION=true
